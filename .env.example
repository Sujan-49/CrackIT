FRONTEND_URL=http://127.0.0.1:5173
API_URL=http://127.0.0.1:4000
VITE_API_URL=http://127.0.0.1:4000/api
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Use strong random values in production.
JWT_SECRET=replace-with-a-long-random-secret
REFRESH_SECRET=replace-with-a-different-long-random-secret
COOKIE_SECURE=false
ADMIN_EMAILS=

# Required only when Google login is configured.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional locally. Required for production MongoDB Atlas persistence.
MONGODB_URI=
MONGODB_DB_NAME=crackit
MONGODB_STRICT=false
